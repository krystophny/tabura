{
  "flowId": "mode-transition",
  "title": "Explicit mode transitions",
  "scenarioRefs": ["@SCN-MODE-001", "@SCN-MODE-002", "@SCN-MODE-003"],
  "states": [
    { "id": "mode_visible", "type": "screen" },
    { "id": "transition_pending", "type": "system" },
    { "id": "transition_rejected", "type": "error" }
  ],
  "transitions": [
    { "id": "m1", "from": "mode_visible", "to": "transition_pending", "trigger": "select_mode" },
    { "id": "m2", "from": "transition_pending", "to": "mode_visible", "trigger": "transition_ok" },
    { "id": "m3", "from": "transition_pending", "to": "transition_rejected", "trigger": "transition_error" }
  ]
}
