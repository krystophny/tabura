{
  "bundleId": "tabula-artifact-bundle-v1",
  "version": "1.0.0",
  "sessionModel": {
    "engineSessionPolicy": "single_shared_cli_session",
    "terminalPanelPolicy": "visibility_only_no_mode_switch"
  },
  "primaryArtifactId": "response-text",
  "artifacts": [
    {
      "artifactId": "response-text",
      "artifactType": "text_response",
      "storagePath": "canonical-text.md",
      "defaultView": "text"
    },
    {
      "artifactId": "latest-diff",
      "artifactType": "diff_patch",
      "storagePath": "latest.patch",
      "defaultView": "diff",
      "optional": true
    }
  ]
}
