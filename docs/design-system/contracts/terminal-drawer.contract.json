{
  "contractId": "terminal-drawer-v1",
  "componentId": "terminal-drawer",
  "version": "1.0.0",
  "scenarioRefs": ["@SCN-TERM-001", "@SCN-TERM-002", "@SCN-TERM-003"],
  "sessionModel": {
    "engineSessionPolicy": "single_shared_cli_session",
    "terminalPanelPolicy": "visibility_only_no_mode_switch"
  },
  "states": [
    { "id": "hidden", "default": true },
    { "id": "visible" },
    { "id": "detached" }
  ],
  "events": [
    { "name": "open_drawer", "result": "attach_to_active_session" },
    { "name": "close_drawer", "result": "hide_without_stopping_session" },
    { "name": "attachment_missing", "result": "show_reattach_actions" }
  ],
  "outputs": [
    { "channel": "visual", "description": "Render PTY output and input continuity" }
  ]
}
