{
  "contractId": "composer-bar-v1",
  "componentId": "composer-bar",
  "version": "1.0.0",
  "scenarioRefs": ["@SCN-CORE-001", "@SCN-CORE-002", "@SCN-CORE-003", "@SCN-WARN-001", "@SCN-WARN-002", "@SCN-WARN-003"],
  "sessionModel": {
    "engineSessionPolicy": "single_shared_cli_session",
    "terminalPanelPolicy": "visibility_only_no_mode_switch"
  },
  "states": [
    { "id": "session_ready", "default": true },
    { "id": "session_missing" },
    { "id": "session_write_failed" }
  ],
  "events": [
    { "name": "submit_prompt", "guard": "session_present", "result": "dispatch_to_session" },
    { "name": "submit_prompt", "guard": "session_missing", "result": "show_recovery_action" },
    { "name": "session_write_failed", "result": "preserve_prompt_for_retry" }
  ],
  "outputs": [
    { "channel": "transport", "description": "Write prompt text to active local PTY session" },
    { "channel": "artifact", "description": "Create canonical turn artifact for completed submissions" }
  ]
}
