{
  "contractId": "canvas-surface-v1",
  "componentId": "canvas-surface",
  "version": "1.0.0",
  "scenarioRefs": ["@SCN-CORE-001", "@SCN-ART-001", "@SCN-ART-002", "@SCN-ART-003"],
  "states": [
    { "id": "blank", "default": true },
    { "id": "single_artifact" }
  ],
  "events": [
    { "name": "turn_completed", "result": "show_latest_artifact" },
    { "name": "artifact_load_failed", "result": "show_recoverable_warning" }
  ],
  "outputs": [
    { "channel": "visual", "description": "Display canonical artifact with optional diff tab" },
    { "channel": "status", "description": "Display advisory warnings and recovery hints" }
  ]
}
