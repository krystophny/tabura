{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["version", "scenarios"],
  "properties": {
    "version": { "type": "string" },
    "updatedAt": { "type": "string" },
    "scenarios": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["scenarioId", "feature", "contractRefs", "flowRefs", "mappingRefs", "bundleRefs"],
        "properties": {
          "scenarioId": { "type": "string" },
          "feature": { "type": "string" },
          "contractRefs": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
          "flowRefs": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
          "mappingRefs": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
          "bundleRefs": { "type": "array", "items": { "type": "string" }, "minItems": 1 }
        }
      }
    }
  },
  "additionalProperties": false
}
