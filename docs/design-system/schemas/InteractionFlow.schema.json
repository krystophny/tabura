    "flowId": { "type": "string" },
    "title": { "type": "string" },
    "scenarioRefs": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "states": { "type": "array", "minItems": 1 },
    "transitions": { "type": "array", "minItems": 1 }
  },
  "additionalProperties": true
}
