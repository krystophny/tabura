{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["contractId", "componentId", "version", "scenarioRefs", "states", "events", "outputs"],
  "properties": {
    "contractId": { "type": "string" },
    "componentId": { "type": "string" },
    "version": { "type": "string" },
    "scenarioRefs": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "states": { "type": "array", "minItems": 1 },
    "events": { "type": "array", "minItems": 1 },
    "outputs": { "type": "array", "minItems": 1 }
  },
  "additionalProperties": true
}
