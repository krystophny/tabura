<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>io.slopshell.web</string>
  <key>ProgramArguments</key>
  <array>
    <string>/bin/bash</string>
    <string>-lc</string>
    <string>set -a; source ~/.config/slopshell/llm.env &gt;/dev/null 2&gt;&amp;1 || true; set +a; exec @@BIN_PATH@@ server --workspace-dir @@PROJECT_DIR@@ --data-dir @@WEB_DATA_DIR@@ --web-host @@SLOPSHELL_WEB_HOST@@ --web-port 8420 --tts-url http://127.0.0.1:8424</string>
  </array>
  <key>EnvironmentVariables</key>
  <dict>
    <key>SLOPSHELL_ASSISTANT_MODE</key>
    <string>local</string>
    <key>SLOPSHELL_HELPY_SOCKET</key>
    <string>@@SLOPSHELL_HELPY_SOCKET@@</string>
    <key>SLOPSHELL_BRAIN_GTD_SYNC</key>
    <string>on</string>
  </dict>
  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <true/>
  <key>StandardOutPath</key>
  <string>/tmp/slopshell-web.log</string>
  <key>StandardErrorPath</key>
  <string>/tmp/slopshell-web.log</string>
</dict>
</plist>
