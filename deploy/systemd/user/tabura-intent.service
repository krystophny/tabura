[Unit]
Description=Tabura Intent Classifier
After=network.target

[Service]
Type=simple
WorkingDirectory=%h/code/assi/tabula/services/intent-classifier
Environment=PYTHONUNBUFFERED=1
ExecStart=%h/code/assi/tabula/services/intent-classifier/.venv/bin/uvicorn main:app --host 127.0.0.1 --port 8425
Restart=on-failure
RestartSec=2

[Install]
WantedBy=default.target
